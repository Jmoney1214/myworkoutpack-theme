<style>
  /* Increased specificity to avoid theme conflicts */
  .amz-header-wrapper * {
    box-sizing: border-box; /* Prevents padding/border issues */
  }

  /* General Variables */
  .amz-header-wrapper {
    --amz-color-primary: #131921;
    --amz-color-secondary: #232F3E;
    --amz-color-accent: #FEBD69;
    --amz-color-accent-hover: #F3A847;
    --amz-border-color: #CDCDCD;
    --amz-text-light: #FFFFFF;
    --amz-text-dark: #0F1111;
  }
  
  /* Base Styles */
  .amz-header-wrapper .amz-header {
    background-color: var(--amz-color-primary);
    color: var(--amz-text-light);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol';
  }

  .amz-header-wrapper .amz-container {
    display: flex;
    align-items: center;
    padding: 0 16px;
    max-width: 1280px;
    margin: 0 auto;
    gap: 24px;
  }

  /* Header Top Belt */
  .amz-header-wrapper .amz-header__top {
    height: 60px;
    padding: 0;
    display: flex;
    align-items: center;
  }
  .amz-header-wrapper .amz-header__top .amz-container { gap: 24px; }
  /* Three-zone layout */
  .amz-header-wrapper .amz-top { display:flex; align-items:center; gap:18px; width:100%; height:60px; }
  .amz-header-wrapper .amz-top__left { flex:0 0 auto; display:flex; align-items:center; gap:14px; min-width:0; }
  .amz-header-wrapper .amz-top__search { flex:1 1 auto; min-width:0; display:flex; }
  .amz-header-wrapper .amz-top__right { flex:0 0 auto; display:flex; align-items:center; justify-content:flex-end; gap:18px; min-width:0; }
  @media (max-width:1200px){ .amz-header-wrapper .amz-top__right{ gap:16px; } }
  
  /* Logo */
  .amz-header-wrapper .amz-logo {
    display: flex;
    align-items: center;
    padding: 0.5rem;
    border: 1px solid transparent;
    border-radius: 0.25rem;
  }
  .amz-header-wrapper .amz-logo:hover {
    border-color: var(--amz-text-light);
  }
  .amz-header-wrapper .amz-logo img { max-height: 28px; }
  
  /* Common "two-line" text style */
  .amz-header-wrapper .amz-two {
    display: none; /* Hidden on small screens */
  }
  @media(min-width: 768px) {
    .amz-header-wrapper .amz-two {
      display: flex;
      flex-direction: column;
      line-height: 1.2;
    }
    .amz-header-wrapper .amz-two__top {
      font-size: 12px;
      line-height: 16px;
      font-weight: 500;
      color: rgba(255,255,255,0.7);
    }
    .amz-header-wrapper .amz-two__bottom {
      font-size: 14px;
      line-height: 20px;
      font-weight: 600;
    }
  }
  
  /* Location */
  .amz-header-wrapper .amz-location {
    display: none; /* Hidden on mobile for simplicity */
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem;
    border: 1px solid transparent;
    border-radius: 0.25rem;
    color: var(--amz-text-light);
    text-decoration: none;
  }
  .amz-header-wrapper .amz-location:hover {
    border-color: var(--amz-text-light);
  }
  @media(min-width: 992px) {
    .amz-header-wrapper .amz-location {
      display: flex;
    }
  }

  /* Search Bar */
  .amz-header-wrapper .amz-search { width:100%; max-width:900px; display:flex; align-items:center; height:40px; border-radius:8px; overflow:hidden; background:#fff; border:1px solid rgba(255,255,255,0.08); box-shadow:none; margin:0; }
  .amz-header-wrapper .amz-search__select {
    display: none;
    background-color: #e6e6e6;
    color: var(--amz-text-dark);
    padding: 0 12px;
    align-items: center;
    font-size: 14px;
    line-height: 20px;
    font-weight: 600;
    border-right: 1px solid rgba(255,255,255,0.08);
    height: 100%;
    width: 72px;
    justify-content: center;
  }
  @media(min-width: 768px) {
    .amz-header-wrapper .amz-search__select { display:inline-flex; }
  }
  .amz-header-wrapper .amz-search__input {
    flex: 1 1 auto; width:100%; border:none; padding:0 14px; font-size:16px; line-height:24px; color:var(--amz-text-dark); height:100%;
  }
  .amz-header-wrapper .amz-search__button { background:var(--amz-color-accent); border:none; width:45px; cursor:pointer; display:flex; align-items:center; justify-content:center; height:100%; border-radius:0 8px 8px 0; }
  /* Group focus outline */
  .amz-header-wrapper .amz-search:focus-within{ outline:2px solid var(--amz-color-accent); outline-offset:2px; }
  .amz-header-wrapper .amz-search__button:hover {
    background-color: var(--amz-color-accent-hover);
  }

  /* Utilities */
  .amz-header-wrapper .amz-utils { display:flex; align-items:center; gap:18px; }
  @media (max-width:1200px){ .amz-header-wrapper .amz-utils{ gap:16px; } }
  .amz-header-wrapper .amz-util {
    padding: 0.5rem;
    border: 1px solid transparent;
    border-radius: 0.25rem;
    text-decoration: none;
    color: var(--amz-text-light);
  }
  .amz-header-wrapper .amz-util:hover {
    border-color: var(--amz-text-light);
  }
  .amz-header-wrapper .amz-account, .amz-header-wrapper .amz-returns {
    display: none; /* Hide on mobile */
  }
  @media(min-width: 768px) {
    .amz-header-wrapper .amz-account, .amz-header-wrapper .amz-returns {
      display: block;
    }
  }
  
  /* Cart */
  .amz-header-wrapper .amz-cart {
    display: flex;
    align-items: flex-end;
    gap: 0.25rem;
  }
  .amz-header-wrapper .amz-cart__iconwrap {
    position: relative;
  }
  .amz-header-wrapper .amz-cart__count {
    position: absolute;
    top: -6px;
    right: -6px;
    background: var(--amz-color-accent);
    color: #111;
    min-width: 18px;
    height: 18px;
    border-radius: 9px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 12px;
    padding: 0 4px;
  }
  .amz-header-wrapper .amz-cart span:last-child {
    display: none;
  }
  @media(min-width: 768px) {
    .amz-header-wrapper .amz-cart span:last-child {
      display: inline;
      font-weight: 700;
      font-size: 0.875rem;
    }
  }
  
  /* Header Nav Belt */
  .amz-header-wrapper .amz-header__nav {
    background-color: var(--amz-color-secondary);
    height: 40px;
    margin-top: 8px;
    display: flex;
    align-items: center;
  }
  .amz-header-wrapper .amz-header__nav .amz-container {
    justify-content: space-between;
  }
  
  .amz-header-wrapper .amz-nav {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 0.5rem 0;
  }
  .amz-header-wrapper .amz-nav a {
    color: var(--amz-text-light);
    text-decoration: none;
    font-size: 14px;
    line-height: 20px;
    font-weight: 600;
    padding: 8px 12px;
    border: 1px solid transparent;
    border-radius: 4px;
  }
  .amz-header-wrapper .amz-nav a:hover {
    border-color: var(--amz-text-light);
  }

  /* Location link emphasis */
  .amz-header-wrapper .amz-two__bottom a { color: #fff; text-decoration: underline; text-underline-offset: 2px; }

  /* Language chip */
  .amz-header-wrapper .amz-lang { display: inline-flex; align-items: center; gap: 6px; padding: 6px 8px; border-radius: 2px; font-weight: 700; }
  .amz-header-wrapper .amz-lang:hover { outline: 1px solid rgba(255,255,255,0.2); }
  
  .amz-header-wrapper .amz-promo {
    display: none; /* Hidden on mobile */
  }
  @media(min-width: 992px) {
    .amz-header-wrapper .amz-promo {
      display: block;
      font-size: 0.875rem;
      font-weight: 700;
    }
  }

  /* Visually Hidden */
  .amz-header-wrapper .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<div class="amz-header-wrapper">
  <header class="amz-header">
    <div class="amz-header__top">
      <div class="amz-container">
        <div class="amz-top">
          <div class="amz-top__left">
            <a class="amz-logo" href="{{ routes.root_url }}">
          {%- if settings.logo != blank -%}
            {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
            {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
            {{ settings.logo | image_url: width: 400 | image_tag:
              class: '',
              width: settings.logo_width,
              alt: logo_alt,
              preload: true
            }}
          {%- else -%}
            <span style="font-weight:800;font-size:1.5rem;">{{ shop.name }}</span>
          {%- endif -%}
            </a>

        {%- if section.settings.show_location -%}
            <a class="amz-location" href="{{ section.settings.location_link | default: '#' }}">
          <div class="amz-location__icon" style="margin-top: 10px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          </div>
          <span class="amz-two">
            <span class="amz-two__top">{{ section.settings.location_label | default: 'Deliver to' }}</span>
            <span class="amz-two__bottom">{{ section.settings.location_value | default: 'United States' }}</span>
          </span>
            </a>
        {%- endif -%}
          </div>

          <div class="amz-top__search">
            <form class="amz-search" action="{{ routes.search_url }}" method="get" role="search">
          <label for="AmzSearchInput-{{ section.id }}" class="visually-hidden">{{ 'general.search.search' | t }}</label>
          <div class="amz-search__select" aria-hidden="true">All&nbsp;▾</div>
          <input id="AmzSearchInput-{{ section.id }}" class="amz-search__input" type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ section.settings.search_placeholder | default: 'Search...' }}">
          <button class="amz-search__button" aria-label="{{ 'general.search.submit' | t }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0F1111" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          </button>
            </form>
          </div>

          <div class="amz-top__right amz-utils">
          {%- if localization.available_languages.size > 0 -%}
            {%- assign current_lang = localization.language.iso_code | upcase -%}
            <a class="amz-util amz-lang" href="#" aria-label="Language">
              <span aria-hidden="true">🇺🇸</span>
              <span>{{ current_lang }}</span>&nbsp;▾
            </a>
          {%- endif -%}
          {%- if section.settings.show_account -%}
            <a class="amz-util amz-account" href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}">
              <span class="amz-two">
                <span class="amz-two__top">Hello, {% if customer %}{{ customer.first_name }}{% else %}sign in{% endif %}</span>
                <span class="amz-two__bottom">Account & Lists</span>
              </span>
            </a>
          {%- endif -%}

          {%- if section.settings.show_returns_orders -%}
            <a class="amz-util amz-returns" href="{{ routes.account_url }}">
              <span class="amz-two">
                <span class="amz-two__top">Returns</span>
                <span class="amz-two__bottom">&amp; Orders</span>
              </span>
            </a>
          {%- endif -%}

          {%- if section.settings.show_cart -%}
            <a class="amz-util amz-cart" href="{{ routes.cart_url }}">
              <span class="amz-cart__iconwrap">
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
                <span class="amz-cart__count">{{ cart.item_count }}</span>
              </span>
              <span>Cart</span>
            </a>
          {%- endif -%}
          </div>
        </div>
      </div>
    </div>

    <div class="amz-header__nav">
      <div class="amz-container">
        <nav class="amz-nav" aria-label="Primary">
          <a href="/collections/all">☰ All</a>
          {%- if section.settings.menu != blank -%}
            {%- for link in section.settings.menu.links -%}
              <a href="{{ link.url }}">{{ link.title }}</a>
            {%- endfor -%}
          {%- endif -%}
        </nav>
        {%- if section.settings.promo_text != blank -%}
          <div class="amz-promo">{{ section.settings.promo_text }}</div>
        {%- endif -%}
      </div>
    </div>
  </header>
</div>

{% schema %}
{
  "name": "Header (Amazon style)",
  "settings": [
    {
      "type": "header",
      "content": "Location"
    },
    {
      "type": "checkbox",
      "id": "show_location",
      "label": "Show location",
      "default": true
    },
    {
      "type": "text",
      "id": "location_label",
      "label": "Location label",
      "default": "Deliver to"
    },
    {
      "type": "text",
      "id": "location_value",
      "label": "Location value",
      "default": "United States"
    },
    {
      "type": "url",
      "id": "location_link",
      "label": "Location link"
    },
    {
      "type": "header",
      "content": "Search"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Search..."
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu"
    },
    {
      "type": "text",
      "id": "promo_text",
      "label": "Right promo text",
      "default": "Shop great deals now"
    },
    {
      "type": "header",
      "content": "Display Options"
    },
    { "type": "checkbox", "id": "show_account", "label": "Show account", "default": true },
    { "type": "checkbox", "id": "show_returns_orders", "label": "Show returns & orders", "default": true },
    { "type": "checkbox", "id": "show_cart", "label": "Show cart", "default": true }
  ],
  "presets": [{ "name": "Header (Amazon style)" }]
}
{% endschema %}
