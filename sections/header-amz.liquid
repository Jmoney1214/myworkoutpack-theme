<link rel="stylesheet" href="{{ 'header-amz.css' | asset_url }}" media="print" onload="this.media='all'">
<header class="amz-header">
  <div class="amz-header__top amz-belt">
    <div class="amz-container">
      <a class="amz-logo" href="{{ routes.root_url }}">
        {%- if settings.logo != blank -%}
          {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
          {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
          {% capture sizes %}(min-width: 750px) {{ settings.logo_width }}px, 40vw{% endcapture %}
          {% capture widths %}{{ settings.logo_width }}, {{ settings.logo_width | times: 1.5 | round }}, {{ settings.logo_width | times: 2 }}{% endcapture %}
          {{ settings.logo | image_url: width: 600 | image_tag:
            class: '',
            widths: widths,
            height: logo_height,
            width: settings.logo_width,
            alt: logo_alt,
            sizes: sizes,
            preload: true
          }}
        {%- else -%}
          <span style="font-weight:800;color:#f59e0b">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      {%- if section.settings.show_location -%}
      <a class="amz-location" href="{{ section.settings.location_link | default: '/pages/delivery' }}">
        <span class="amz-location__icon"><img src="{{ 'icon-map-pin.svg' | asset_url }}" alt="" width="16" height="16" loading="lazy"></span>
        <span class="amz-two">
          <span class="amz-two__top">{{ section.settings.location_label | default: 'Deliver to' }}</span>
          <span class="amz-two__bottom">{{ section.settings.location_value | default: 'Your location' }}</span>
        </span>
      </a>
      {%- endif -%}

      <form class="amz-search" action="{{ routes.search_url }}" method="get" role="search">
        <label for="AmzSearchInput-{{ section.id }}" class="visually-hidden">{{ 'general.search.search' | t }}</label>
        <select class="amz-search__select" aria-label="Category">
          <option>All</option>
        </select>
        <input id="AmzSearchInput-{{ section.id }}" class="amz-search__input" type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ section.settings.search_placeholder | default: 'Search' }}" />
        <button class="amz-search__button" aria-label="{{ 'general.search.submit' | t }}">
          <img src="{{ 'icon-search.svg' | asset_url }}" alt="" width="20" height="20" loading="lazy">
        </button>
      </form>

      <div class="amz-utils">
        {%- if section.settings.show_language and localization.available_languages.size > 0 -%}
          {%- assign current_lang = localization.language.iso_code | upcase -%}
          <a class="amz-lang" href="#" aria-label="Language">
            {{ current_lang }} ▾
          </a>
        {%- endif -%}
        {%- if section.settings.show_account -%}
          <a class="amz-util amz-account" href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}">
            <span class="amz-two">
              <span class="amz-two__top">{{ 'customer.login.sign_in' | t | default: 'Hello, sign in' }}</span>
              <span class="amz-two__bottom">{{ 'layout.customer.account' | t | default: 'Account & Lists' }}</span>
            </span>
          </a>
        {%- endif -%}

        {%- if section.settings.show_returns_orders -%}
          <a class="amz-util amz-returns" href="{{ routes.account_url }}">
            <span class="amz-two">
              <span class="amz-two__top">Returns</span>
              <span class="amz-two__bottom">&amp; Orders</span>
            </span>
          </a>
        {%- endif -%}

        {%- if section.settings.show_cart -%}
          <a class="amz-util amz-cart" href="{{ routes.cart_url }}">
            <img src="{{ 'icon-cart.svg' | asset_url }}" alt="" width="24" height="24" loading="lazy">
            <span class="amz-cart__count">{%- if cart != empty -%}{{ cart.item_count }}{%- else -%}0{%- endif -%}</span>
            <span>{{ 'layout.cart.title' | t | default: 'Cart' }}</span>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="amz-header__nav amz-main">
    <div class="amz-container">
      <nav class="amz-nav" aria-label="Primary">
        <a href="/collections/all">☰ {{ 'sections.header.all' | t | default: 'All' }}</a>
        {%- if section.settings.menu != blank -%}
          {%- for link in section.settings.menu.links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endfor -%}
        {%- endif -%}
      </nav>
      {%- if section.settings.promo_text != blank -%}
        <div class="amz-promo">{{ section.settings.promo_text }}</div>
      {%- endif -%}
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header (Amazon style)",
  "settings": [
    { "type": "checkbox", "id": "show_language", "label": "Show language", "default": true },
    {
      "type": "checkbox",
      "id": "show_location",
      "label": "Show location",
      "default": true
    },
    {
      "type": "text",
      "id": "location_label",
      "label": "Location label",
      "default": "Deliver to"
    },
    {
      "type": "text",
      "id": "location_value",
      "label": "Location value",
      "default": "United States"
    },
    {
      "type": "url",
      "id": "location_link",
      "label": "Location link"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Search"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu"
    },
    { "type": "checkbox", "id": "show_account", "label": "Show account", "default": true },
    { "type": "checkbox", "id": "show_returns_orders", "label": "Show returns & orders", "default": true },
    { "type": "checkbox", "id": "show_cart", "label": "Show cart", "default": true },
    { "type": "text", "id": "promo_text", "label": "Right promo text", "default": "Shop great deals now" }
  ],
  "presets": [{ "name": "Header (Amazon style)" }]
}
{% endschema %}
