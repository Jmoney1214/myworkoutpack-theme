<header style="background:#121a24;color:#fff;">
  <div style="max-width:1280px;margin:0 auto;padding:10px 16px;display:flex;gap:16px;align-items:center;">
    <a href="/" style="background:#000;padding:10px 16px;border-radius:4px;color:#f59e0b;font-weight:800;text-decoration:none">MyStore</a>
    <div style="display:flex;align-items:center;flex:1;max-width:980px;">
      <div style="background:#e9ecf1;border-radius:8px 0 0 8px;padding:10px 14px;font-weight:600;color:#334155">All ▾</div>
      <input type="search" placeholder="Search MyStore" style="flex:1;padding:12px 14px;border:0;background:#f4f6f8;color:#111827;outline:none">
      <button aria-label="Search" style="background:#f6b400;border:0;padding:10px 16px;border-radius:0 8px 8px 0">🔍</button>
    </div>
    <a href="/cart" style="color:#fff;text-decoration:none;display:flex;align-items:center;gap:8px">🛒<span id="hdrCartCount">0</span></a>
  </div>
  <nav style="background:#1a2532">
    <div style="max-width:1280px;margin:0 auto;padding:10px 16px;display:flex;gap:24px;white-space:nowrap;overflow:auto">
      <a href="/collections/all" style="color:#fff;text-decoration:none;display:flex;gap:8px">☰ All</a>
      <a href="#" style="color:#fff;text-decoration:none">Medical Care</a>
      <a href="#" style="color:#fff;text-decoration:none">Luxury</a>
      <a href="#" style="color:#fff;text-decoration:none">Best Sellers</a>
      <a href="#" style="color:#fff;text-decoration:none">Amazon Basics</a>
      <a href="#" style="color:#fff;text-decoration:none">New Releases</a>
      <a href="#" style="color:#fff;text-decoration:none">Groceries</a>
      <a href="#" style="color:#fff;text-decoration:none">Prime</a>
      <a href="#" style="color:#fff;text-decoration:none">Today's Deals</a>
    </div>
  </nav>
</header>

{% schema %}
{
  "name": "Header (Amazon style)",
  "settings": [],
  "presets": [{ "name": "Header (Amazon style)" }]
}
{% endschema %}
