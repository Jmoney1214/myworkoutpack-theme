{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .hero-overlap { position: relative; }
  .hero-overlap__slider { position:relative; overflow:hidden }
  .hero-overlap__cards {
    position: relative;
    z-index: 2;
    max-width: var(--page-width, 1200px);
    margin: -72px auto 0 auto; /* mimic Amazon overlap depth */
    padding: 0 20px 10px;
  }
  .hero-overlap__grid { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:18px }
  .hero-overlap__card { background:#fff; border-radius:10px; border:1px solid #e5e7eb; box-shadow:0 8px 18px rgba(0,0,0,.08); overflow:hidden }
  .hero-overlap__card-in { padding:18px }
  .hero-overlap__card h3 { margin:0 0 12px; font:700 20px/1.25 Inter,system-ui,sans-serif; color:#111 }
  .hero-overlap__tiles{ display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:14px }
  .hero-overlap__tile{ background:#fff }
  .hero-overlap__img { width:100%; height:112px; object-fit:cover; display:block; background:#f5f5f5; border:1px solid #efefef; border-radius:6px }
  .hero-overlap__caption{ margin:6px 2px 0; font:500 12px/1.25 Inter,system-ui,sans-serif; color:#222 }
  .hero-overlap__cta{ display:inline-block; margin-top:14px; color:#146eb4; font-weight:600; text-decoration:none }
  .hero-overlap__cta:hover{ text-decoration:underline }
  /* slider height + arrow placement */
  .hero-overlap .banner--large .slideshow__media { min-height: 280px }
  .hero-overlap .banner--medium .slideshow__media { min-height: 240px }
  .hero-overlap .banner--small .slideshow__media { min-height: 200px }
  .hero-overlap__slider .slider-buttons{ position:absolute; inset:auto 12px 0 12px; top:50%; transform:translateY(-50%); display:flex; justify-content:space-between; pointer-events:none }
  .hero-overlap__slider .slider-button{ pointer-events:auto; background:#fff; border-radius:999px; width:36px; height:36px; display:flex; align-items:center; justify-content:center; box-shadow:0 2px 8px rgba(0,0,0,.25) }
  /* text overlay on banner */
  .hero-overlap__content{ position:absolute; inset:0 auto 0 0; display:flex; align-items:center; }
  .hero-overlap__content-in{ max-width:min(48ch, 50%); margin-left: max(20px, 5%); color:#fff }
  .hero-overlap__headline{ margin:0; font:800 40px/1.05 Inter,system-ui,sans-serif; letter-spacing:-.4px }
  .hero-overlap__sub{ margin:10px 0 0; font:700 18px/1.15 Inter,system-ui,sans-serif }
  @media(max-width: 990px){ .hero-overlap__grid{ grid-template-columns:1fr } .hero-overlap__cards{ margin-top:-30px } }
{%- endstyle -%}

<div class="hero-overlap">
  <slideshow-component
    class="hero-overlap__slider slider-mobile-gutter"
    role="region"
    aria-roledescription="{{ 'sections.slideshow.carousel' | t }}"
    aria-label="{{ section.settings.accessibility_info | escape }}"
  >
    <div
      class="slideshow banner banner--{{ section.settings.slide_height }} grid grid--1-col slider slider--everywhere{% if section.blocks.first.settings.image == blank %} slideshow--placeholder{% endif %}"
      id="Slider-{{ section.id }}"
      aria-live="polite"
      aria-atomic="true"
      data-autoplay="{{ section.settings.auto_rotate }}"
      data-speed="{{ section.settings.change_slides_speed }}"
    >
      {%- for block in section.blocks -%}
        {%- if block.type == 'slide' -%}
          <div class="slideshow__slide grid__item grid--1-col slider__slide" id="Slide-{{ section.id }}-{{ forloop.index }}" {{ block.shopify_attributes }}>
            <div class="slideshow__media banner__media media{% if block.settings.image == blank %} placeholder{% endif %}">
              {%- if block.settings.image -%}
                {% assign load_mode = 'eager' %}
                {% if forloop.index > 1 %}{% assign load_mode = 'lazy' %}{% endif %}
                {{ block.settings.image | image_url: width: 2400 | image_tag: loading: load_mode, sizes: '100vw', widths: '750, 1100, 1500, 2000, 2400' }}
              {%- else -%}
                {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            {%- if block.settings.headline != blank or block.settings.subheading != blank -%}
              <div class="hero-overlap__content">
                <div class="hero-overlap__content-in">
                  {%- if block.settings.headline != blank -%}<h2 class="hero-overlap__headline">{{ block.settings.headline }}</h2>{%- endif -%}
                  {%- if block.settings.subheading != blank -%}<p class="hero-overlap__sub">{{ block.settings.subheading }}</p>{%- endif -%}
                </div>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
    <div class="slideshow__controls slider-buttons">
      <button type="button" class="slider-button slider-button--prev" name="previous" aria-controls="Slider-{{ section.id }}">
        <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
      </button>
      <button type="button" class="slider-button slider-button--next" name="next" aria-controls="Slider-{{ section.id }}">
        <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
      </button>
    </div>
  </slideshow-component>

  <div class="hero-overlap__cards">
    <div class="hero-overlap__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'promo' -%}
          <div class="hero-overlap__card" {{ block.shopify_attributes }}>
            <div class="hero-overlap__card-in">
              <h3>{{ block.settings.title }}</h3>
              <div class="hero-overlap__tiles">
                <div class="hero-overlap__tile">
                  {%- if block.settings.image1 != blank -%}
                    {{ block.settings.image1 | image_url: width: 450 | image_tag: class: 'hero-overlap__img', loading: 'lazy' }}
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'hero-overlap__img' }}
                  {%- endif -%}
                  {%- if block.settings.caption1 != blank -%}<div class="hero-overlap__caption">{{ block.settings.caption1 }}</div>{%- endif -%}
                </div>
                <div class="hero-overlap__tile">
                  {%- if block.settings.image2 != blank -%}
                    {{ block.settings.image2 | image_url: width: 450 | image_tag: class: 'hero-overlap__img', loading: 'lazy' }}
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'hero-overlap__img' }}
                  {%- endif -%}
                  {%- if block.settings.caption2 != blank -%}<div class="hero-overlap__caption">{{ block.settings.caption2 }}</div>{%- endif -%}
                </div>
                <div class="hero-overlap__tile">
                  {%- if block.settings.image3 != blank -%}
                    {{ block.settings.image3 | image_url: width: 450 | image_tag: class: 'hero-overlap__img', loading: 'lazy' }}
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'hero-overlap__img' }}
                  {%- endif -%}
                  {%- if block.settings.caption3 != blank -%}<div class="hero-overlap__caption">{{ block.settings.caption3 }}</div>{%- endif -%}
                </div>
                <div class="hero-overlap__tile">
                  {%- if block.settings.image4 != blank -%}
                    {{ block.settings.image4 | image_url: width: 450 | image_tag: class: 'hero-overlap__img', loading: 'lazy' }}
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'hero-overlap__img' }}
                  {%- endif -%}
                  {%- if block.settings.caption4 != blank -%}<div class="hero-overlap__caption">{{ block.settings.caption4 }}</div>{%- endif -%}
                </div>
              </div>
              {%- if block.settings.cta_label != blank and block.settings.cta_link != blank -%}
                <a class="hero-overlap__cta" href="{{ block.settings.cta_link }}">{{ block.settings.cta_label }}</a>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero slider with promos",
  "tag": "section",
  "class": "section hero-overlap",
  "settings": [
    { "type": "select", "id": "slide_height", "label": "Slide height", "default": "large", "options": [
      {"value": "small", "label": "Small"},
      {"value": "medium", "label": "Medium"},
      {"value": "large", "label": "Large"},
      {"value": "adapt_image", "label": "Adapt to first image"}
    ]},
    { "type": "checkbox", "id": "auto_rotate", "label": "Auto rotate slides", "default": true },
    { "type": "range", "id": "change_slides_speed", "min": 3, "max": 9, "step": 1, "default": 5, "label": "Slide change speed (s)" },
    { "type": "text", "id": "accessibility_info", "label": "Accessibility label", "default": "Pickleball promotions" }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 5,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Slide image" },
        { "type": "text", "id": "headline", "label": "Headline", "default": "Labor Day Sale" },
        { "type": "text", "id": "subheading", "label": "Subheading", "default": "Up to 40% off Pickleball" }
      ]
    },
    {
      "type": "promo",
      "name": "Promo card",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Promo" },
        { "type": "image_picker", "id": "image1", "label": "Tile 1 image" },
        { "type": "text", "id": "caption1", "label": "Tile 1 caption", "default": "Paddles" },
        { "type": "image_picker", "id": "image2", "label": "Tile 2 image" },
        { "type": "text", "id": "caption2", "label": "Tile 2 caption", "default": "Balls" },
        { "type": "image_picker", "id": "image3", "label": "Tile 3 image" },
        { "type": "text", "id": "caption3", "label": "Tile 3 caption", "default": "Nets" },
        { "type": "image_picker", "id": "image4", "label": "Tile 4 image" },
        { "type": "text", "id": "caption4", "label": "Tile 4 caption", "default": "Bags" },
        { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop the sale" },
        { "type": "url", "id": "cta_link", "label": "CTA link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero + 3 promos (pickleball)",
      "blocks": [
        {"type": "slide"}, {"type": "slide"},
        {"type": "promo", "settings": {"title": "Specials"}},
        {"type": "promo", "settings": {"title": "Sales"}},
        {"type": "promo", "settings": {"title": "New items"}}
      ]
    }
  ]
}
{% endschema %}
